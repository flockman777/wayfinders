# Database (PostgreSQL) - Gunakan Vercel Postgres, Neon, atau Supabase
DATABASE_URL="postgresql://user:password@host:5432/wayfinders"
DIRECT_URL="postgresql://user:password@host:5432/wayfinders"

# NextAuth
NEXTAUTH_URL="https://your-app.vercel.app"
NEXTAUTH_SECRET="generate-random-string-min-32-chars"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Xendit Payment
XENDIT_SECRET_KEY="xnd_development_YOUR_KEY_HERE"
XENDIT_WEBHOOK_TOKEN="your-webhook-token"
XENDIT_CALLBACK_TOKEN="your-callback-token"

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_URL=""

# SMTP Email (optional)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# App
NEXT_PUBLIC_BASE_URL="https://your-app.vercel.app"
NEXT_PUBLIC_APP_NAME="Wayfinders"
